{
  "name": "agentdiff",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CI for agent behavior changes",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentdiff-ai/agentdiff.git"
  },
  "bin": {
    "agentdiff": "packages/cli/bin/agentdiff.js"
  },
  "dependencies": {
    "openai": "^6.44.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "agentdiff": "node packages/cli/bin/agentdiff.js",
    "demo": "node packages/cli/bin/agentdiff.js demo",
    "classify:demo": "node packages/cli/bin/agentdiff.js classify --files examples/support-ticket-agent/head/src/supportAgent.js",
    "scan:demo": "node packages/cli/bin/agentdiff.js scan --root examples/support-ticket-agent/head --out .agentdiff/map.json",
    "stranger": "node scripts/stranger-test.js",
    "stranger:self": "node scripts/stranger-test.js --mode self-test",
    "stranger:bakeoff": "node scripts/stranger-test.js --mode repo-bakeoff",
    "lab": "node scripts/agent-repo-lab.js",
    "lab:agent-repos": "node scripts/agent-repo-lab.js",
    "study": "node scripts/real-repo-study.js",
    "study:repos": "node scripts/real-repo-study.js",
    "study:repos:all50": "node scripts/real-repo-study.js --all",
    "study:audit-action-required": "node scripts/action-required-audit.js",
    "study:pr-mining": "node scripts/pr-mining-study.js",
    "study:open-prs": "node scripts/open-pr-watchlist.js",
    "zoo": "node scripts/agent-zoo-test.js",
    "zoo:update": "node scripts/agent-zoo-test.js --update",
    "zoo:live": "node scripts/agent-zoo-live-openrouter.js",
    "video": "npm --prefix examples/remotion-demo run video",
    "outreach:draft": "node scripts/outreach/draft.js docs/outreach-targets.example.json",
    "test": "node tests/diff-extraction.test.mjs && node tests/map-drift.test.mjs && node tests/coding-agent-trace.test.mjs && node tests/openrouter-harness.test.mjs && node tests/outreach-draft.test.mjs && node tests/scan-limits.test.mjs && node tests/import-graph.test.mjs && node tests/reachability-provenance.test.mjs && node tests/action-required-gold.test.mjs && node tests/report-actionability.test.mjs && node tests/suppressions.test.mjs && node tests/init.test.mjs && node packages/cli/bin/agentdiff.js demo --out .agentdiff/runs/latest"
  }
}
