{
  "name": "agentdiff",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CI for agent behavior changes",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "agentdiff": "node packages/cli/bin/agentdiff.js",
    "demo": "node packages/cli/bin/agentdiff.js demo",
    "classify:demo": "node packages/cli/bin/agentdiff.js classify --files examples/support-ticket-agent/head/src/supportAgent.js",
    "scan:demo": "node packages/cli/bin/agentdiff.js scan --root examples/support-ticket-agent/head --out .agentdiff/map.json",
    "test": "node packages/cli/bin/agentdiff.js demo --out .agentdiff/runs/latest"
  }
}
